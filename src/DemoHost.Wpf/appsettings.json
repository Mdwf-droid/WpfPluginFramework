{
  "PluginSettings": {
    "Directories": [
      {
        "Path": "Plugins",
        "Recursive": true,
        "Optional": false,
        "Priority": 1
      },
      {
        "Path": "Plugins/Experimental",
        "Recursive": true,
        "Optional": true,
        "Priority": 50
      }
    ],
    "SearchPattern": "*.Plugin.dll",
    "MaxRecursionDepth": 10,
    "IgnoreHiddenDirectories": true,
    "IgnoreDirectories": [ ".git", "bin", "obj", ".vs" ],
    "DataDirectory": "PluginData",
    "HttpPort": 5100,
    "LoadTimeoutSeconds": 30,
    "EnableFileWatching": true,
    "FileWatcherDebounceMs": 2000,
    "CircuitBreakerMaxFailures": 3,
    "CircuitBreakerCooldownMinutes": 5
  }
}
